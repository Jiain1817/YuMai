[
  {
    "id": 1,
    "title": "萨迦格言·第1则",
    "ethnic": "藏族",
    "region": "西藏",
    "category": "格言",
    "intro": "智者学识似宝库，积聚珍宝诸格言。",
    "keywords": ["智慧", "格言", "藏族文化"],
    "characters": [],
    "content": {
      "zh": "智者学识似宝库，积聚珍宝诸格言。万水归处为大海，是故百川终汇流",
      "original": "མཁས་པ་|ཡོན་ཏན་|མཛོད་འཛིན་|པ། དེ་དག་|ལེགས་བཤད་|རིན་ཆེན་|བསྡུས། རྒྱ་མཚོ་|ཆེན་པོ་|ཆུ་བོའི་|གཏེར། ཡིན་ཕྱིར་|ཆུ་བོ་|ཐམས་ཅད་|འབབ།"
    },
    "moral": "",
    "source": "萨迦格言集",
    "collector": ""
  },
  {
    "id": 2,
    "title": "萨迦格言·第2则",
    "ethnic": "藏族",
    "region": "西藏",
    "category": "格言",
    "intro": "明晨将死学勿辍，此生或未成智者，",
    "keywords": ["智慧", "格言", "藏族文化"],
    "characters": [],
    "content": {
      "zh": "明晨将死学勿辍，此生或未成智者，所学好似储来世，易取恰如在囊中。",
      "original": "རིག་པ་|ནངས་པར་|འཆི་ཡང་|སློབ། ཚེ་འདིར་|མཁས་པར་|མ་འགྱུར་|ཡང་། སྐྱེ་བ་|ཕྱི་མར་|བཅོལ་བ་|ཡིས། ནོར་ལ་|རང་ཉིད་|ལེན་པ་|འདྲ།"
    },
    "moral": "",
    "source": "萨迦格言集",
    "collector": ""
  },
  {
    "id": 3,
    "title": "萨迦格言·第3则",
    "ethnic": "藏族",
    "region": "西藏",
    "category": "格言",
    "intro": "先哲教法善品性，自有圣贤广宣扬。",
    "keywords": ["智慧", "格言", "藏族文化"],
    "characters": [],
    "content": {
      "zh": "先哲教法善品性，自有圣贤广宣扬。马拉雅山檀香味，随风飘溢传八方。",
      "original": "རྟག་ཏུ་དམ་པའི་ཡོན་ཏན་རྣམས། སྐྱེ་བོ་དམ་པས་ལྷག་པར་སྒྲོགས། མ་ལ་ཡ་ཡི་ཙན་དན་དྲི། རླུང་གིས་ཕྱོགས་བཅུར་རྒྱས་པར་བྱེད།"
    },
    "moral": "",
    "source": "萨迦格言集",
    "collector": ""
  },
  {
    "id": 4,
    "title": "萨迦格言·第4则",
    "ethnic": "藏族",
    "region": "西藏",
    "category": "格言",
    "intro": "赞誉加身处泰然，毁谤袭来亦如故，",
    "keywords": ["智慧", "格言", "藏族文化"],
    "characters": [],
    "content": {
      "zh": "赞誉加身处泰然，毁谤袭来亦如故，宠辱不惊谨自持，方为圣人真品行。",
      "original": "བསྟོད་པས་དགའ་བར་མི་འགྱུར་ལ། སྨད་པས་མི་དགར་མི་འགྱུར་ཞིང་། རང་གི་ཡོན་ཏན་ལེགས་གནས་པ། སྐྱེ་བོ་དམ་པའི་མཚན་ཉིད་ཡིན།"
    },
    "moral": "",
    "source": "萨迦格言集",
    "collector": ""
  },
  {
    "id": 5,
    "title": "萨迦格言·第5则",
    "ethnic": "藏族",
    "region": "西藏",
    "category": "格言",
    "intro": "但凡愚人做事业，毁坏事体毁坏己。",
    "keywords": ["智慧", "格言", "藏族文化"],
    "characters": [],
    "content": {
      "zh": "但凡愚人做事业，毁坏事体毁坏己。好似狐狸做兽王，难保属民难保己。",
      "original": "བླུན་པོ་བྱ་བ་ལ་སྦྱར་ན། དོན་ཉམས་དེ་ཡང་ཉམས་པར་འགྱུར། ཝ་སྐྱེས་རྒྱལ་པོར་བསྐོས་པ་ཡིས། འཁོར་སྡུག་རང་ཡང་བསད་ཅེས་གྲགས"
    },
    "moral": "",
    "source": "萨迦格言集",
    "collector": ""
  },
  {
    "id": 6,
    "title": "萨迦格言·第6则",
    "ethnic": "藏族",
    "region": "西藏",
    "category": "格言",
    "intro": "学高智者人自慕，无须呼引接踵至。",
    "keywords": ["智慧", "格言", "藏族文化"],
    "characters": [],
    "content": {
      "zh": "学高智者人自慕，无须呼引接踵至。花香袭人虽处远，蜂群自是似云来。",
      "original": "ཡོན་ཏན་ལྡན་ན་སྐྱེ་བོ་ཀུན། མ་བསྡུས་པར་ཡང་རང་ཉིད་འདུ། དྲི་ལྡན་མེ་ཏོག་རྒྱང་རིང་ཡང་། བུང་བ་སྤྲིན་གྱི་ཚོགས་བཞིན་འཁོར།"
    },
    "moral": "",
    "source": "萨迦格言集",
    "collector": ""
  },
  {
    "id": 7,
    "title": "萨迦格言·第7则",
    "ethnic": "藏族",
    "region": "西藏",
    "category": "格言",
    "intro": "愚人偶能成事业，非其所能运使然。",
    "keywords": ["智慧", "格言", "藏族文化"],
    "characters": [],
    "content": {
      "zh": "愚人偶能成事业，非其所能运使然。蚕虫口中所吐丝，不是业精天所赐。",
      "original": "བླུན་པོས་བྱ་བ་ལེགས་གྲུབ་ཀྱང་། སྟེས་དབང་ཡིན་གྱི་བསྒྲུབས་པས་མིན། སྲིན་འབུའི་ཁ་ཆུ་དར་སྐུད་དུ། འགྲོ་བ་མཁས་ནས་བྱུང་བ་མིན།"
    },
    "moral": "",
    "source": "萨迦格言集",
    "collector": ""
  },
  {
    "id": 8,
    "title": "萨迦格言·第8则",
    "ethnic": "藏族",
    "region": "西藏",
    "category": "格言",
    "intro": "智者能明格言义，愚人安能明其理。",
    "keywords": ["智慧", "格言", "藏族文化"],
    "characters": [],
    "content": {
      "zh": "智者能明格言义，愚人安能明其理。好似日升光芒照，鸱鸮却将双目合。",
      "original": "ལེགས་བཤད་མཁས་པའི་བློ་གྲོས་ཀྱིས། གོ་ཡི་བླུན་པོས་དེ་ལྟ་མིན། ཉི་མའི་འོད་ཟེར་ཤར་བ་ན། འབྱུང་པོའི་བྱ་རྣམས་ལོང་བར་འགྱུར།"
    },
    "moral": "",
    "source": "萨迦格言集",
    "collector": ""
  },
  {
    "id": 9,
    "title": "萨迦谚语·第1则",
    "ethnic": "藏族",
    "region": "西藏",
    "category": "谚语",
    "intro": "人之所倚血肉，畜之所赖水草。",
    "keywords": ["谚语", "民间智慧"],
    "characters": [],
    "content": {
